{
  "name": "rooz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:web": "tsx server.ts",
    "dev:extension": "tsx server.ts",
    "build:web": "BUILD_TARGET=web vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist-web/server.cjs",
    "build:extension": "BUILD_TARGET=extension vite build && esbuild packages/extension/src/background.ts --bundle --platform=browser --outfile=dist-extension/background.js && esbuild packages/extension/src/content.ts --bundle --platform=browser --outfile=dist-extension/content.js && node copy_assets.cjs",
    "build": "npm run build:web && npm run build:extension",
    "start": "node dist-web/server.cjs",
    "clean": "rm -rf dist dist-web dist-extension server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^26.3.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pngjs": "^7.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "vite": "^6.2.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
